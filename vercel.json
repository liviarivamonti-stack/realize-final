{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/artifacts/crm/dist/public/assets/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/artifacts/crm/dist/public/index.html"
    }
  ],
  "functions": {
    "api/index.ts": {
      "includeFiles": "lib/db/src/**,artifacts/api-server/src/**"
    }
  }
}
